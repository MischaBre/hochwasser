# Public domains used by Caddy host routing
PUBLIC_APP_DOMAIN=app.example.com
PUBLIC_API_DOMAIN=api.example.com

# Profiles: prod => watchdog + caddy + frontend-prod + external DB
COMPOSE_PROFILES=prod

# Database and migrations (recommended: managed Supabase Postgres)
DATABASE_URL=postgresql://engine_user:CHANGE_ME_ENGINE_PASSWORD@db.<project-ref>.supabase.co:6543/postgres?sslmode=require
FLYWAY_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
FLYWAY_USER=postgres
FLYWAY_PASSWORD=CHANGE_ME_DB_PASSWORD

# Alert service
PROVIDER=pegelonline
FORECAST_SERIES_SHORTNAME=WV
ALERT_DEDUPE_HOURS=24
LOG_LEVEL=INFO
TZ=Europe/Berlin
ALERT_RECIPIENTS=admin@example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_SENDER=alerts@example.com
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

# API (Supabase Auth)
API_DATABASE_URL=postgresql://api_user:CHANGE_ME_API_PASSWORD@db.<project-ref>.supabase.co:6543/postgres?sslmode=require
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_AUDIENCE=authenticated
API_DEFAULT_ORG_ID=11111111-1111-1111-1111-111111111111
API_INITIAL_ADMIN_USER_ID=
API_AUTO_PROVISION_MEMBERS=true
API_CORS_ALLOW_ORIGINS=https://app.example.com

# Frontend build-time vars
VITE_API_BASE_URL=https://api.example.com
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=CHANGE_ME_SUPABASE_PUBLISHABLE_KEY

# Watchdog (optional but enabled in prod profile)
WATCHDOG_ALERT_RECIPIENTS=alerts@example.com
WATCHDOG_COOLDOWN_SECONDS=900
