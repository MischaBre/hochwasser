SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-user@example.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER=alerts@example.com
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
ALERT_RECIPIENTS=admin@example.com
# Profiles: dev => local Postgres, prod => watchdog + external DB
COMPOSE_PROFILES=dev
# Local persistent Postgres in docker-compose
DATABASE_URL=postgresql://hochwasser:hochwasser@postgres:5432/hochwasser
# Recommended once DB roles are bootstrapped:
# DATABASE_URL=postgresql://engine_user:CHANGE_ME_ENGINE_PASSWORD@postgres:5432/hochwasser
FLYWAY_URL=jdbc:postgresql://postgres:5432/hochwasser
FLYWAY_USER=hochwasser
FLYWAY_PASSWORD=hochwasser
# Supabase pooler example:
# DATABASE_URL=postgresql://postgres:your-password@db.<project-ref>.supabase.co:6543/postgres?sslmode=require
# FLYWAY_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# FLYWAY_USER=postgres
# FLYWAY_PASSWORD=your-password
TZ=Europe/Berlin

WATCHDOG_ALERT_RECIPIENTS=alerts@example.com
WATCHDOG_COOLDOWN_SECONDS=900

# API (Supabase Auth)
API_DATABASE_URL=postgresql://hochwasser:hochwasser@postgres:5432/hochwasser
# Recommended once DB roles are bootstrapped:
# API_DATABASE_URL=postgresql://api_user:CHANGE_ME_API_PASSWORD@postgres:5432/hochwasser
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_AUDIENCE=authenticated
API_DEFAULT_ORG_ID=11111111-1111-1111-1111-111111111111
API_INITIAL_ADMIN_USER_ID=
API_AUTO_PROVISION_MEMBERS=true
API_CORS_ALLOW_ORIGINS=http://localhost:3000
