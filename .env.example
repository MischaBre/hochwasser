PROVIDER=pegelonline
DATABASE_URL=postgresql://hochwasser:hochwasser@postgres:5432/hochwasser
FLYWAY_URL=jdbc:postgresql://postgres:5432/hochwasser
FLYWAY_USER=hochwasser
FLYWAY_PASSWORD=hochwasser
# Supabase pooler example:
# DATABASE_URL=postgresql://postgres:my-password@db.<project-ref>.supabase.co:6543/postgres?sslmode=require
# FLYWAY_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# FLYWAY_USER=postgres
# FLYWAY_PASSWORD=my-password
FORECAST_SERIES_SHORTNAME=WV

ALERT_DEDUPE_HOURS=24
LOG_LEVEL=DEBUG
TZ=Europe/Berlin

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=my-user
SMTP_PASSWORD=my-password
SMTP_SENDER=hochwasser-alert@example.com
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
ALERT_RECIPIENTS=admin@example.com
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8090
HEALTH_FAILURE_THRESHOLD=3

WATCHDOG_ALERT_RECIPIENTS=alice@example.com,bob@example.com
WATCHDOG_WATCH_CONTAINERS=hochwasser-alert
WATCHDOG_COOLDOWN_SECONDS=900
WATCHDOG_AUTO_RESTART_UNHEALTHY=true
